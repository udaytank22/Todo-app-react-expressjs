generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  password             String
  name                 String
  role                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  comments             Comment[]
  customerAssignments  CustomerAssignment[]  @relation("CustomerAssignmentUser")
  receivedMessages     DirectMessage[]       @relation("ReceivedMessages")
  sentMessages         DirectMessage[]       @relation("SentMessages")
  notifications        Notification[]        @relation("UserNotifications")
  archiveNotifications NotificationArchive[] @relation("UserArchiveNotifications")
  refreshTokens        RefreshToken[]        @relation("UserRefreshTokens")
  teams                Team[]                @relation("UserTeams")
  statusLogs           StatusHistory[]
  tasksAssigned        Task[]                @relation("TaskAssignee")
}

model Email {
  id              String   @id @default(uuid())
  messageId       String   @unique
  subject         String
  senderEmail     String
  senderName      String
  body            String
  receivedAt      DateTime
  processedStatus String
  createdAt       DateTime @default(now())
  task            Task?
}

model Task {
  id             String                   @id @default(uuid())
  inquiryId      String                   @unique // Custom counter e.g., "INQ-1001"
  subject        String
  customerName   String
  senderEmail    String
  description    String                   @db.Text
  status         String // "PENDING", "IN_PROGRESS", "COMPLETED", "CANCELLED"
  priority       String // "LOW", "MEDIUM", "HIGH", "URGENT"
  dueDate        DateTime?
  externalLink   String?
  remarks        String?                  @db.Text
  aiSummary      String?                  @db.Text
  assignedUserId String?
  assignedUser   User?                    @relation("TaskAssignee", fields: [assignedUserId], references: [id])
  groupId        String?
  group          TaskGroup?               @relation(fields: [groupId], references: [id], onDelete: SetNull)
  teamId         String?
  team           Team?                    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  emailId        String?                  @unique
  email          Email?                   @relation(fields: [emailId], references: [id], onDelete: SetNull)
  attachments    Attachment[]
  comments       Comment[]
  statusHistory  StatusHistory[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  search_vector  Unsupported("tsvector")? @default(dbgenerated())

  @@index([status])
  @@index([priority])
  @@index([assignedUserId])
  @@index([groupId])
  @@index([teamId])
  @@index([createdAt])
}

model TaskGroup {
  id        String   @id @default(uuid())
  name      String   @unique
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id                  String               @id @default(uuid())
  name                String               @unique
  users               User[]               @relation("UserTeams")
  customerAssignments CustomerAssignment[]
  tasks               Task[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Attachment {
  id        String   @id @default(uuid())
  filename  String
  filePath  String
  fileType  String
  fileSize  Int
  taskId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model StatusHistory {
  id          String   @id @default(uuid())
  taskId      String
  fromStatus  String
  toStatus    String
  changedById String?
  changedAt   DateTime @default(now())
  changedBy   User?    @relation(fields: [changedById], references: [id])
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model AiLog {
  id             String   @id @default(uuid())
  emailMessageId String
  prompt         String
  rawResponse    String
  status         String
  errorMsg       String?
  createdAt      DateTime @default(now())

  @@index([emailMessageId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  relatedId String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

model NotificationArchive {
  id         String   @id
  userId     String
  type       String
  title      String
  message    String
  relatedId  String
  isRead     Boolean  @default(false)
  createdAt  DateTime
  archivedAt DateTime @default(now())
  user       User     @relation("UserArchiveNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Counter {
  id        String   @id @default("inquiry_counter")
  value     Int      @default(1000)
  updatedAt DateTime @updatedAt
}

model CustomerAssignment {
  id             String   @id @default(uuid())
  customerName   String?
  customerEmail  String?
  assignedUserId String?
  assignedUser   User?    @relation("CustomerAssignmentUser", fields: [assignedUserId], references: [id], onDelete: Cascade)
  teamId         String?
  team           Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([customerName, customerEmail])
}

model IntegrationToken {
  provider     String   @id
  accessToken  String
  refreshToken String?
  expiryTime   BigInt?
  updatedAt    DateTime @updatedAt
}

model DirectMessage {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation("UserRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
