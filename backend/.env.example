# PORT: Port the backend server listens on. If missing, defaults to 5000.
PORT=5001

# NODE_ENV: Server environment (development, production). If missing, defaults to 'development'.
NODE_ENV=development

# DATABASE_URL: PostgreSQL connection string. If missing, the server will fail to start.
DATABASE_URL=postgresql://postgres@localhost:5432/task_inquiry_db?schema=public&connection_limit=15&pool_timeout=30

# DATABASE_READ_URL: PostgreSQL read replica connection string. If missing, falls back to DATABASE_URL.
DATABASE_READ_URL=postgresql://postgres@localhost:5432/task_inquiry_db?schema=public

# JWT_SECRET: Secret key for signing JSON Web Tokens. If missing, the server will fail to start.
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# GEMINI_API_KEY: Google Gemini API key. If missing, logs a warning and falls back to a regex heuristic parser.
GEMINI_API_KEY=your_gemini_api_key_here

# CORS_ORIGIN: Origin allowed to make CORS requests to the API. If missing, defaults to http://localhost:5173.
CORS_ORIGIN=http://localhost:5173

# REDIS_URL: Redis server connection URL. If missing, defaults to redis://127.0.0.1:6379 (falls back gracefully to in-memory mode if unreachable).
REDIS_URL=redis://127.0.0.1:6379

# DEMO_MODE: Enable simulated email sync without Azure credentials. If missing, defaults to false.
DEMO_MODE=true

# MICROSOFT_CLIENT_ID: Azure Application (client) ID. If missing and DEMO_MODE is false, Outlook synchronization will fail.
MICROSOFT_CLIENT_ID=your_client_id_here

# MICROSOFT_CLIENT_SECRET: Azure Application Client Secret. If missing and DEMO_MODE is false, Outlook synchronization will fail.
MICROSOFT_CLIENT_SECRET=your_client_secret_here

# MICROSOFT_TENANT_ID: Azure Tenant ID. If missing, defaults to 'common'.
MICROSOFT_TENANT_ID=common

# MICROSOFT_REDIRECT_URI: OAuth Redirect URI for Outlook callback. If missing and DEMO_MODE is false, authorization will fail.
MICROSOFT_REDIRECT_URI=http://localhost:5001/api/emails/callback

# MOBILE_ENCRYPTION_KEY: E2E Mobile encryption key (32+ chars). If missing, the server will fail to start.
MOBILE_ENCRYPTION_KEY=super_secure_mobile_encrypt_key_32_chars

# S3_BUCKET: AWS S3 Bucket name for file uploads. If missing, the app falls back to local disk storage.
S3_BUCKET=

# AWS_REGION: AWS region for S3 bucket. If missing, defaults to 'us-east-1'.
AWS_REGION=us-east-1

# AWS_ACCESS_KEY_ID: AWS access key ID. If missing, the app falls back to local disk storage.
AWS_ACCESS_KEY_ID=

# AWS_SECRET_ACCESS_KEY: AWS secret access key. If missing, the app falls back to local disk storage.
AWS_SECRET_ACCESS_KEY=

# LOG_LEVEL: Minimum level for Winston logger. If missing, defaults to 'info'.
LOG_LEVEL=info
