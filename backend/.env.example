# Backend Port
PORT=5000
NODE_ENV=development

DATABASE_URL=postgresql://username:password@localhost:5432/task_inquiry_db?schema=public&connection_limit=15&pool_timeout=30

# Required: Generate a long random string (e.g. using `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
JWT_SECRET=super_secret_jwt_key_change_me_in_production
GEMINI_API_KEY=your_gemini_api_key_here
CORS_ORIGIN=http://localhost:5173

# ─── Phase 1: Redis (optional but recommended for production) ───────────────
# When Redis is running, rate limiting and Socket.IO use shared state so the app
# can scale to multiple instances. If Redis is unavailable, the app falls back
# gracefully to in-memory mode (suitable for single-instance development).
REDIS_URL=redis://127.0.0.1:6379

# Enable simulation mode by default so the app is testable without Azure setups.
# Switch to false if using actual Microsoft Graph credentials.
DEMO_MODE=true

# Microsoft Graph API credentials (only needed if DEMO_MODE=false)
MICROSOFT_CLIENT_ID=your_client_id_here
MICROSOFT_CLIENT_SECRET=your_client_secret_here
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:5000/api/emails/callback
